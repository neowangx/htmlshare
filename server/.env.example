PORT=8090
UPLOAD_TOKEN=change-me
# Required. Signs the access-code session cookie; without it the server refuses to start.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
DATA_DIR=./data
MAX_PAGE_MB=20
UNLOCK_RATE_LIMIT=5
RETAIN_VERSIONS=20
# Set TRUST_PROXY=1 when behind a reverse proxy so unlock rate-limiting uses X-Forwarded-For.
TRUST_PROXY=0
# Set COOKIE_SECURE=1 when served over HTTPS.
COOKIE_SECURE=0
